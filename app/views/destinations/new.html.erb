<div id='map'></div>

<turbo-frame id="destination-form">
<%= form_with model: @destination, url: destinations_path, class: "contents" do |f| %>
  <div class="my-5">
    <%= f.label :name %>
    <%= f.text_field :name, class: "block shadow rounded-md border border-gray-200 outline-none px-3 py-2 mt-2 w-full" %>
  </div>
  <div class="my-5">
    <%= f.label :address %>
    <%= f.text_field :address, class: "block shadow rounded-md border border-gray-200 outline-none px-3 py-2 mt-2 w-full" %>
  </div>
  <div class="my-5">
    <%= f.label :distance %>
    <%= f.number_field :distance, id: 'js-get-distance', class: "block shadow rounded-md border border-gray-200 outline-none px-3 py-2 mt-2 w-full" %>
  </div>
  <div class="my-5">
    <%= f.check_box :is_saved, class: "shadow rounded-md border border-gray-200 px-3.5 py-1 inline mr-3" %>
    <%= f.label :is_saved, '目的地を保存する' %>
  </div>
  <%= f.hidden_field :latitude %>
  <%= f.hidden_field :longitude %>
  <div class="text-right mb-5">
    <%= f.submit 'スタート画面へ', class: "rounded-lg py-3 px-5 bg-orange-600 text-white font-medium cursor-pointer" %>
  </div>
<% end %>
</turbo-frame>

<%= include_gon %>

<%= javascript_include_tag 'show-route' %>
<%= javascript_include_tag Settings.google.map_url, async: 'async', defer: 'defer' %>
