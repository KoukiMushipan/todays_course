<%= turbo_frame_tag history do %>
  <div class="p-4 w-full text-center rounded-lg border shadow-md sm:p-8 mb-4 font-noto bg-sky-50">
    <p class="mb-2 text-base text-gray-600 sm:text-lg"><%= history.decorate.from_what_time_to_what_time %></p>
    <p class="mb-1 text-base text-gray-700 sm:text-lg"><%= history.decorate.from_where_to_where %></p>

    <h5 class="mb-4 text-3xl font-bold text-gray-900 break-words"><%= "#{history.decorate.calc_time}分 #{history.moving_distance.to_s}m" %></h5>

    <div class="justify-center items-center">
      <%= link_to (t '.show_route'), set_history_path(history),
      data: { turbo_method: :post, turbo_frame: "_top" },
      class: 'w-3/5 sm:w-1/2 bg-orange-600 text-white rounded-lg inline-flex items-center justify-center px-4 py-3.5 font-semibold drop-shadow-lg mb-2' %>
      <div data-controller="dropdown">
        <div class="relative pb-1 sm:pb-0">
          <div class="text-gray-500 mb-2 dropdown-icon" data-action="click->dropdown#open" data-dropdown-target="openButton">
            <%= fa_icon "chevron-down"%>
          </div>
          <div class="text-gray-500 mb-2 dropdown-icon hidden" data-action="click->dropdown#close" data-dropdown-target="closeButton">
            <%= fa_icon "chevron-up" %>
          </div>
        </div>
        <div class="hidden" data-dropdown-target="menu">
          <%= link_to (t '.edit'), edit_history_path(history),
          class: 'w-1/3 bg-slate-500 text-white rounded-lg inline-flex items-center justify-center px-3 py-1.5 drop-shadow-lg mr-2 mt-4',
          data: { turbo: false } %>

          <%= link_to (t '.destroy'), history_path(history),
          data: { turbo_method: :delete, turbo_confirm: (t '.delete_confirm')},
          class: 'w-1/3 bg-gray-500 text-white rounded-lg inline-flex items-center justify-center px-3 py-1.5 drop-shadow-lg mb-4 ml-2 mt-4' %>
        </div>
      </div>
    </div>
  </div>
<% end %>
