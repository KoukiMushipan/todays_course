<%= form_with url: login_path, class: "contents" do |f| %>
  <div class="my-5">
    <%= f.label :email, User.human_attribute_name(:email) %>
    <%= f.email_field :email, class: "block shadow rounded-md border border-gray-200 outline-none px-3 py-2 mt-2 w-full" %>
  </div>

  <div class="my-5">
    <%= f.label :password, User.human_attribute_name(:password) %>
    <%= f.password_field :password, class: "block shadow rounded-md border border-gray-200 outline-none px-3 py-2 mt-2 w-full" %>
  </div>

  <div class="text-right">
    <%= f.submit (t 'defaults.login'), class: "rounded-lg py-3 px-5 bg-orange-600 text-white font-medium cursor-pointer" %>
  </div>
<% end %>
