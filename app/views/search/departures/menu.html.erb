<div>
  <h1 class="font-bold text-4xl"><%= t '.title' %></h1>

  <div data-controller="location">
    <button
    data-action='click->location#getLocation'
    class="bg-orange-500 text-white font-bold py-2 px-4 rounded block my-10">
    <%= t '.get_current_location' %>
    </button>
  </div>

  <div class='block my-10'>
    <%= link_to (t '.input_address'), search_departure_input_path, class: "bg-orange-500 text-white font-bold py-2 px-4 rounded" %>
  </div>
  <div class='block my-10'>
    <%= link_to (t '.select_saved_departures'), search_departure_saved_path, class: "bg-orange-500 text-white font-bold py-2 px-4 rounded" %>
  </div>
  <div class='block my-10'>
    <%= link_to (t '.select_departure_histories'), search_departure_histories_path, class: "bg-orange-500 text-white font-bold py-2 px-4 rounded" %>
  </div>

  <%= form_with model: @search_departure, url: search_departure_from_current_location_path do |f| %>
    <%= f.hidden_field :latitude, id: 'js-get-latitude' %>
    <%= f.hidden_field :longitude, id: 'js-get-longitude' %>
    <%= f.submit id: 'js-location-submit', class: 'hidden' %>
  <% end %>
</div>
