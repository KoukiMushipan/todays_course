<%= form_with model: @search_departure, url: search_departure_from_address_path, class: "contents" do |f| %>
  <div class="my-5">
    <%= f.label :name, (t 'defaults.place_name') %>
    <%= f.text_field :name, class: "block shadow rounded-md border border-gray-200 px-3 py-2 mt-2 w-full" %>
  </div>

  <div class="my-5">
    <%= f.label :address, (t 'defaults.address') %>
    <%= f.text_field :address, class: "block shadow rounded-md border border-gray-200 px-3 py-2 mt-2 w-full" %>
  </div>

  <div class="my-5">
    <%= f.check_box :is_saved, class: "shadow rounded-md border border-gray-200 px-3.5 py-1 inline mr-3" %>
    <%= f.label :is_saved, (t '.save') %>
  </div>

  <div class="text-right">
    <%= link_to (t '.not_fix'), search_terms_path, class: "rounded-lg py-3.5 px-5 bg-orange-600 text-white font-medium cursor-pointer drop-shadow-lg" %>
    <%= f.submit (t '.fix'), class: "rounded-lg py-3 px-5 bg-orange-600 text-white font-medium cursor-pointer drop-shadow-lg" %>
  </div>
<% end %>
