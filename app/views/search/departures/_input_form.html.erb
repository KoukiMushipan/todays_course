<%= form_with model: search_departure, url: search_departure_from_input_path, class: "contents" do |f| %>
  <div class="my-5">
    <%= f.label :name, (t 'defaults.place_name') %>
    <%= f.text_field :name, class: "block shadow rounded-md border border-gray-200 px-3 py-2 mt-2 w-full" %>
    <%= render partial: 'shared/error_message', collection: search_departure.errors.full_messages_for(:name) %>
  </div>

  <div class="my-5">
    <%= f.label :address, (t 'defaults.address') %>
    <%= f.text_field :address, class: "block shadow rounded-md border border-gray-200 px-3 py-2 mt-2 w-full", required: true %>
    <%= render partial: 'shared/error_message', collection: search_departure.errors.full_messages_for(:address) %>
  </div>

  <div class="my-5">
    <%= f.check_box :is_saved, class: "shadow rounded-md border border-gray-200 px-3.5 py-1 inline mr-3" %>
    <%= f.label :is_saved, (t '.save') %>
  </div>

  <div class="text-right">
    <%= f.submit (t '.next'), class: "rounded-lg py-3 px-5 bg-orange-600 text-white font-medium cursor-pointer drop-shadow-lg" %>
  </div>
<% end %>
