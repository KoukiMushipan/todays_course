<%= turbo_frame_tag Departure.new do %>
  <div class="p-4 w-full rounded-lg border shadow-md sm:p-8 mb-4 bg-cyan-50">
    <div class="justify-center items-center">
      <%= form_with model: @search_departure, url: departures_path, class: "contents" do |f| %>
        <div class="my-5">
          <%= f.label :name %>
          <%= f.text_field :name, class: "block shadow rounded-md border border-gray-200 outline-none px-3 py-2 mt-2 w-full" %>
          <%= render partial: 'shared/error_message', collection: @search_departure.errors.full_messages_for(:name) %>
        </div>
        <div class="my-5">
          <%= f.label :address %>
          <%= f.text_field :address, class: "block shadow rounded-md border border-gray-200 outline-none px-3 py-2 mt-2 w-full" %>
          <%= render partial: 'shared/error_message', collection: @search_departure.errors.full_messages_for(:address) %>
        </div>
        <div class="text-right mb-5">
          <%= link_to 'キャンセル', cancel_departures_path, class: "rounded-lg mt-3 px-5 text-gray-700 font-normal cursor-pointer underline" %>
          <%= f.submit class: "rounded-lg py-2.5 px-5 bg-orange-600 text-white font-medium cursor-pointer" %>
        </div>
      <% end %>
    </div>
  </div>
<% end %>
